{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2020"],
    "target": "ES2020",
    "strict": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "outDir": "./dist",
    "rootDir": "./"
  },
  "include": ["./src/**/*", "./config/**/*", "./plugins/**/*", "./index.js"],
  "exclude": ["node_modules", "build", "dist", ".tmp"]
}
