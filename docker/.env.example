# Database
DATABASE_CLIENT=postgres
DATABASE_HOST=strapiDB
DATABASE_PORT=5432
DATABASE_NAME=license_server
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi

# Redis
REDIS_URL=redis://strapi-redis:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
ADMIN_JWT_SECRET=your-super-secret-admin-jwt-key-change-in-production

# App Keys
APP_KEYS=key1,key2,key3,key4

# License Server
LICENSE_CA_CERT_PATH=/etc/ssl/certs/ca.crt
LICENSE_CA_KEY_PATH=/etc/ssl/private/ca.key
LICENSE_SERVER_SECRET=your-license-server-secret-change-in-production
LICENSE_WEBHOOK_SECRET=your-dedicated-webhook-secret-change-in-production
LICENSE_SIGNER_AUTH_TOKEN=change-me-signer-token
LICENSE_SIGNER_SHARED_SECRET=change-me-signer-shared-secret
LICENSE_SIGNER_TLS_CA_PATH=
LICENSE_SIGNER_TLS_CERT_PATH=
LICENSE_SIGNER_TLS_KEY_PATH=
LICENSE_SIGNER_FRESHNESS_MAX_SKEW_SECONDS=60
CERT_SIGNER_AUTH_MAX_SKEW=60s
CERT_SIGNER_TLS_CERT_PATH=
CERT_SIGNER_TLS_KEY_PATH=
CERT_SIGNER_TLS_CLIENT_CA_PATH=
LICENSE_PROXY_SHARED_SECRET=replace-with-random-nginx-to-strapi-secret
LICENSE_WEBHOOK_ALLOWED_IPS=
LICENSE_MTLS_ENDPOINT=https://api
LICENSE_GRACE_PERIOD_DAYS=7
LICENSE_HEARTBEAT_HOURS=24
LICENSE_MAX_ACTIVATIONS=3
LICENSE_REQUIRE_MTLS=true
LICENSE_FRESHNESS_MAX_SKEW_SECONDS=300
LICENSE_WEBHOOK_FRESHNESS_MAX_SKEW_SECONDS=300
LICENSE_REQUIRE_FRESHNESS_STORE=true

# Node
NODE_ENV=development
