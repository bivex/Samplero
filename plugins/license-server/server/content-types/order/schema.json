{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order",
    "description": "Customer orders"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "required": true
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::license-server.order-item",
      "mappedBy": "order"
    },
    "total_amount_cents": {
      "type": "integer",
      "required": true,
      "min": 0
    },
    "subtotal_amount_cents": {
      "type": "integer",
      "nullable": true,
      "min": 0
    },
    "discount_amount_cents": {
      "type": "integer",
      "nullable": true,
      "min": 0
    },
    "currency": {
      "type": "enumeration",
      "enum": ["USD", "EUR", "GBP"],
      "default": "USD"
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "paid", "failed", "refunded"],
      "default": "pending"
    },
    "payment_method": {
      "type": "enumeration",
      "enum": ["card", "paypal", "crypto", "coupon"],
      "nullable": true
    },
    "coupon": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::license-server.coupon",
      "inversedBy": "orders",
      "nullable": true
    },
    "coupon_code": {
      "type": "string",
      "nullable": true
    },
    "payment_id": {
      "type": "string",
      "nullable": true,
      "description": "External payment provider ID"
    },
    "paid_at": {
      "type": "datetime",
      "nullable": true
    }
  }
}
