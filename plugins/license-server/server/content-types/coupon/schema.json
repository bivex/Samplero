{
  "kind": "collectionType",
  "collectionName": "coupons",
  "info": {
    "singularName": "coupon",
    "pluralName": "coupons",
    "displayName": "Coupon",
    "description": "Admin-issued coupon codes that can fully discount an order"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "code": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "covers_full_amount": {
      "type": "boolean",
      "default": true
    },
    "max_redemptions": {
      "type": "integer",
      "nullable": true,
      "min": 1
    },
    "redemption_count": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "starts_at": {
      "type": "datetime",
      "nullable": true
    },
    "expires_at": {
      "type": "datetime",
      "nullable": true
    },
    "notes": {
      "type": "text",
      "nullable": true
    },
    "orders": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::license-server.order",
      "mappedBy": "coupon"
    }
  }
}